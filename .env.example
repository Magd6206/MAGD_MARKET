# ─── SERVER PORTS ──────────────────────────────────────────────────────────────
# IMPORTANT: Backend and Frontend run as TWO independent processes.
# Do NOT share or mirror these port values between the two configs.

# Backend API (Express + MongoDB) — always port 3000
BACKEND_PORT=3000

# Frontend static server (http-server / serve) — always port 5000
# The backend CORS policy is locked to this value.
FRONTEND_URL=http://localhost:5000

# ─── DATABASE ───────────────────────────────────────────────────────────────────
MONGODB_URI=

# ─── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY="your_access_token_secret_here"
REFRESH_JWT_SECRET_KEY="your_refresh_token_secret_here"

# ─── ADMIN SEED ─────────────────────────────────────────────────────────────────
ADMIN_NAME="admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="strongpassword"

# ─── CLOUDINARY ─────────────────────────────────────────────────────────────────
CLOUD_NAME="your_cloud_name"
API_KEY_CLOUD="your_api_key"
API_SECRET_CLOUD="your_api_secret"
