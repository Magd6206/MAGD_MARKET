# ════════════════════════════════════════════════════════════════════════════
# MAGD MARKET — Environment Variables Reference
# Copy this file to .env and fill in your values.
# ════════════════════════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────────────────────────
# PORT: injected automatically by Render/Heroku. Set to 3000 locally.
PORT=3000

# BASE_URL: the public URL of this deployment. Used for CORS origin matching.
# Local:      BASE_URL=http://localhost:3000
# Production: BASE_URL=https://your-app.onrender.com
BASE_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_access_token_secret_min_32_chars
REFRESH_JWT_SECRET_KEY=your_refresh_token_secret_min_32_chars

# ─── Admin Seed ──────────────────────────────────────────────────────────────
ADMIN_NAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=strongpassword123

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUD_NAME=your_cloud_name
API_KEY_CLOUD=your_api_key
API_SECRET_CLOUD=your_api_secret
